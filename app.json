{
  "expo": {
    "name": "Leben in Deutschland Test",
    "slug": "leben-in-deutschland",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "scheme": "ryg",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.rygapps.lebenindeutschland",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.rygapps.lebenindeutschland",
      "versionCode": 1,
      "splits": { "abi": { "enable": true } },
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6f798c4c-3fac-4cf4-b0cd-4d397bc510c9"
      }
    }
  }
}

{
  "expo": {
    "name": "Leben in Deutschland Test",
    "slug": "leben-in-deutschland",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "scheme": "ryg",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d1117"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.rygapps.lebenindeutschland",
      "buildNumber": "1",
      "splash": {
        "image": "./assets/icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#050505"
      }
    },
    "android": {
      "package": "com.rygapps.lebenindeutschland",
      "splits": { "abi": { "enable": true } },
      "enableProguardInReleaseBuilds": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#111111"
      },
      "splash": {
        "image": "./assets/icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#050505"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      ["expo-splash-screen", {
        "image": "./assets/splash-icon.png",
        "imageWidth": 200,
        "backgroundColor": "#0d1117"
      }],
      ["react-native-google-mobile-ads", {
        "androidAppId": "ca-app-pub-3293228392983133~1995458193",
        "iosAppId": "ca-app-pub-3293228392983133~1339485098"
      }]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6f798c4c-3fac-4cf4-b0cd-4d397bc510c9"
      }
    }
  }
}
